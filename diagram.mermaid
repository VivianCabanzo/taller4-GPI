flowchart LR
    A["Simulacion: 01_simular.R"] --> B["Datos simulados"]
    B --> C{"Procesamiento: 02_procesar.R"}
    C --> D["datos procesados"]
    D --> E["Análisis de datos: 03_analizar.R"] & G["Modelamiento: 04_modelar.R"] & I["Visualización: 05_visualizar.R"]
    E --> F["Tabla descriptiva: ingreso_promedio"]
    G --> H["Modelo Logit: modelo_resumen"]
    I --> J["Boxplot: box_ingreso_grupo"] & K["Histograma: hist_ingreso"]

    A@{ shape: diam}
    B@{ shape: cyl}
    D@{ shape: cyl}
    E@{ shape: diam}
    G@{ shape: diam}
    I@{ shape: diam}
    F@{ shape: hex}
    H@{ shape: hex}
    J@{ shape: hex}
    K@{ shape: hex}
     A:::Sky
     B:::Peach
     C:::Sky
